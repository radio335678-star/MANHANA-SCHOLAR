# ─── Supabase project: manthana-scholer (ref: lziejvvfmreprdnuifwx) ───
# Dashboard: https://supabase.com/dashboard/project/lziejvvfmreprdnuifwx
#
# Copy to .env for local dev. Never commit .env.
# Set the same values in Render (API) and Vercel (VITE_* only) dashboards.

# Supabase Postgres pooler (port 6543, transaction mode)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

SUPABASE_URL=https://lziejvvfmreprdnuifwx.supabase.co
SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SUPABASE_SERVICE_ROLE_KEY]
SUPABASE_STORAGE_BUCKET=thesis-artifacts

# Vercel build-time only (browser)
VITE_SUPABASE_URL=https://lziejvvfmreprdnuifwx.supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]

# Render API only — Moonshot Kimi (never expose to frontend)
KIMI_API_KEY=[YOUR_KIMI_API_KEY]
KIMI_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_WEB_SEARCH=true
KIMI_PRIMARY_MODEL=kimi-k2.6
KIMI_FALLBACK_MODELS=kimi-k2.5

# Local API port (Render uses PORT instead)
API_PORT=5000
NODE_ENV=development

# Production API: comma-separated frontend origins (optional if using Vercel /api proxy)
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Web dev (artifacts/web/.env)
# PORT=22333
# BASE_PATH=/
